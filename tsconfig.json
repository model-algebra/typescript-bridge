{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "jsx": "preserve",

    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,

    "outDir": "dist",
    "sourceMap": true,

    "lib": ["ES2022", "DOM"],

    "types": ["vitest/globals"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
